# ==========================================
# CONFIGURACIÓN DE NGROK (TÚNEL HTTPS)
# ==========================================
# 1. Obtené tu authtoken en: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=tu_authtoken_aqui

# 2. Reclamá tu dominio estático en: https://dashboard.ngrok.com/cloud-edge/domains
# Formato: lo-que-sea.ngrok-free.app (SIN https://)
NGROK_DOMAIN=tu_dominio.ngrok-free.app

# ==========================================
# CONFIGURACIÓN DE N8N
# ==========================================
# Zona horaria para que los turnos y fechas coincidan con Argentina
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires
